<UserControl x:Class="VtccpApp.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource SurfaceBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- header + buttons -->
            <RowDefinition Height="Auto" />  <!-- filter bar -->
            <RowDefinition Height="*"    />  <!-- DataGrid -->
            <RowDefinition Height="Auto" />  <!-- detail strip -->
            <RowDefinition Height="Auto" />  <!-- status bar -->
        </Grid.RowDefinitions>

        <!-- ── Header ──────────────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Results History"
                       Style="{StaticResource SectionHeader}"
                       Margin="0" VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                <Button Content="Copy TSV"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding CopyCommand}"
                        Margin="0,0,8,0" />
                <Button Content="Clear Filters"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding ClearFiltersCommand}"
                        Margin="0,0,8,0" />
                <Button Content="Clear History"
                        Style="{StaticResource DangerButton}"
                        Command="{Binding ClearCommand}" />
            </StackPanel>
        </StackPanel>

        <!-- ── Filter bar ──────────────────────────────────────────── -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,12" Padding="12,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Grade:" VerticalAlignment="Center"
                           Style="{StaticResource FieldLabel}" Margin="0,0,8,0" />
                <ComboBox ItemsSource="{Binding GradeOptions}"
                          SelectedItem="{Binding GradeFilter, Mode=TwoWay}"
                          Width="80" Margin="0,0,20,0" />

                <TextBlock Text="Pass/Fail:" VerticalAlignment="Center"
                           Style="{StaticResource FieldLabel}" Margin="0,0,8,0" />
                <ComboBox ItemsSource="{Binding PassFailOptions}"
                          SelectedItem="{Binding PassFailFilter, Mode=TwoWay}"
                          Width="90" Margin="0,0,20,0" />

                <TextBlock Text="Symbology contains:" VerticalAlignment="Center"
                           Style="{StaticResource FieldLabel}" Margin="0,0,8,0" />
                <TextBox Text="{Binding SymbologyFilter, UpdateSourceTrigger=PropertyChanged}"
                         Width="160" />
            </StackPanel>
        </Border>

        <!-- ── Results DataGrid ────────────────────────────────────── -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <DataGrid ItemsSource="{Binding FilteredRecords}"
                      SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserSortColumns="True"
                      CanUserResizeColumns="True"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                      Background="Transparent"
                      BorderThickness="0"
                      RowBackground="White"
                      AlternatingRowBackground="#F8F9FA"
                      HeadersVisibility="Column"
                      SelectionMode="Single"
                      FontFamily="{StaticResource AppFont}"
                      FontSize="{StaticResource FontNormal}">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background"      Value="{StaticResource SurfaceBrush}" />
                        <Setter Property="Foreground"      Value="{StaticResource TextSecondaryBrush}" />
                        <Setter Property="FontSize"        Value="11" />
                        <Setter Property="FontWeight"      Value="SemiBold" />
                        <Setter Property="Padding"         Value="10,8" />
                        <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}" />
                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding"         Value="10,5" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#1A2980B9" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>

                    <!-- # -->
                    <DataGridTextColumn Header="#"
                                        Binding="{Binding RowNumber}"
                                        Width="46"
                                        ElementStyle="{StaticResource DataGridCenteredCell}" />

                    <!-- Time -->
                    <DataGridTextColumn Header="Time"
                                        Binding="{Binding Time}"
                                        Width="76" />

                    <!-- Symbology -->
                    <DataGridTextColumn Header="Symbology"
                                        Binding="{Binding Symbology}"
                                        Width="180" />

                    <!-- Grade — numeric primary, letter secondary, colour-coded -->
                    <DataGridTemplateColumn Header="Grade" Width="76"
                                            SortMemberPath="NumericGrade">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="4" Padding="6,3"
                                        Margin="2" HorizontalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#BDC3C7" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Grade}" Value="A">
                                                    <Setter Property="Background" Value="#27AE60" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Grade}" Value="B">
                                                    <Setter Property="Background" Value="#2ECC71" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Grade}" Value="C">
                                                    <Setter Property="Background" Value="#F39C12" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Grade}" Value="D">
                                                    <Setter Property="Background" Value="#E67E22" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Grade}" Value="F">
                                                    <Setter Property="Background" Value="#E74C3C" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel HorizontalAlignment="Center">
                                        <!-- Numeric grade — primary -->
                                        <TextBlock Text="{Binding NumericGradeDisplay}"
                                                   Foreground="White"
                                                   FontWeight="Bold"
                                                   FontSize="13"
                                                   HorizontalAlignment="Center" />
                                        <!-- Letter grade — secondary -->
                                        <TextBlock Text="{Binding Grade}"
                                                   Foreground="#DDEEFF"
                                                   FontSize="10"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,-1,0,0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Pass/Fail — coloured -->
                    <DataGridTemplateColumn Header="Pass/Fail" Width="80"
                                            SortMemberPath="PassFail">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding PassFail}"
                                           HorizontalAlignment="Center"
                                           FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground"
                                                    Value="{StaticResource TextSecondaryBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PassFail}" Value="Pass">
                                                    <Setter Property="Foreground"
                                                            Value="{StaticResource SuccessBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding PassFail}" Value="Fail">
                                                    <Setter Property="Foreground"
                                                            Value="{StaticResource DangerBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- UEC% -->
                    <DataGridTextColumn Header="UEC%"
                                        Binding="{Binding UecPercent, StringFormat={}{0:F1}}"
                                        Width="62"
                                        ElementStyle="{StaticResource DataGridCenteredCell}" />

                    <!-- Decoded Data (preview; click row to see full) -->
                    <DataGridTemplateColumn Header="Decoded Data" Width="*"
                                            SortMemberPath="DecodedDataPreview">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding DecodedDataPreview}"
                                               VerticalAlignment="Center" />
                                    <!-- "…more" hint when truncated -->
                                    <TextBlock Text=" ⤵"
                                               FontSize="10"
                                               Foreground="{StaticResource AccentBrush}"
                                               VerticalAlignment="Center"
                                               ToolTip="Click row to see full decoded data"
                                               Visibility="{Binding IsTruncated,
                                                   Converter={StaticResource BoolToVisibility}}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Operator -->
                    <DataGridTextColumn Header="Operator"
                                        Binding="{Binding OperatorId}"
                                        Width="100" />

                    <!-- Job -->
                    <DataGridTextColumn Header="Job"
                                        Binding="{Binding JobName}"
                                        Width="130" />

                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- ── Detail strip (visible when a row is selected) ───────── -->
        <Border Grid.Row="3"
                Margin="0,8,0,0"
                BorderBrush="{StaticResource AccentBrush}"
                BorderThickness="0,0,0,0"
                CornerRadius="6"
                Visibility="{Binding HasSelection, Converter={StaticResource BoolToVisibility}}">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#F0F7FF" Offset="0" />
                    <GradientStop Color="#E8F4FD" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid Margin="16,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Row 1: grade summary + metadata -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Grade pill -->
                    <Border Grid.Column="0" CornerRadius="4"
                            Padding="10,4" Margin="0,0,16,0"
                            Background="{StaticResource AccentBrush}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding DetailGrade}"
                                       Foreground="White" FontWeight="SemiBold"
                                       FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <!-- Symbology + device -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding DetailSymbology}"
                                   FontWeight="SemiBold" FontSize="13"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="{Binding DetailDevice}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>

                    <!-- Timestamp + operator -->
                    <StackPanel Grid.Column="2" HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding DetailDateTime}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Right" />
                        <TextBlock Text="{Binding DetailOperator}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Right" />
                    </StackPanel>
                </Grid>

                <!-- Row 2: label -->
                <TextBlock Grid.Row="1"
                           Text="FULL DECODED DATA"
                           Style="{StaticResource FieldLabel}"
                           Margin="0,0,0,4" />

                <!-- Row 3: full decoded data — selectable, wrapping, scrollable -->
                <Border Grid.Row="2"
                        Background="White"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="10,8"
                        MaxHeight="100">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto">
                        <TextBox Text="{Binding DetailFullDecode, Mode=OneWay}"
                                 IsReadOnly="True"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontFamily="Consolas, Courier New, monospace"
                                 FontSize="12"
                                 TextWrapping="Wrap"
                                 VerticalAlignment="Stretch" />
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>

        <!-- ── Status bar ──────────────────────────────────────────── -->
        <Border Grid.Row="4" Margin="0,8,0,0" Padding="8,4"
                Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusMessage}"
                       Style="{StaticResource StatusText}" />
        </Border>
    </Grid>
</UserControl>
