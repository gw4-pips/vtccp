<UserControl x:Class="VtccpApp.Views.SessionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource SurfaceBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- header -->
            <RowDefinition Height="Auto" />  <!-- setup card -->
            <RowDefinition Height="Auto" />  <!-- scan mode bar -->
            <RowDefinition Height="*"    />  <!-- live area -->
            <RowDefinition Height="Auto" />  <!-- status bar -->
        </Grid.RowDefinitions>

        <!-- ── Page header ─────────────────────────────────────────── -->
        <TextBlock Grid.Row="0" Text="Session Launcher"
                   Style="{StaticResource SectionHeader}" />

        <!-- ── Setup card ──────────────────────────────────────────── -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Device -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="DEVICE PROFILE" Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding AvailableDevices}"
                              SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
                              DisplayMemberPath="Name"
                              IsEnabled="{Binding IsRunning, Converter={StaticResource InvertBool}}" />
                </StackPanel>

                <!-- Template -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="JOB TEMPLATE" Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding AvailableTemplates}"
                              SelectedItem="{Binding SelectedTemplate, Mode=TwoWay}"
                              DisplayMemberPath="Name"
                              IsEnabled="{Binding IsRunning, Converter={StaticResource InvertBool}}" />
                </StackPanel>

                <!-- Operator override -->
                <StackPanel Grid.Column="4">
                    <TextBlock Text="OPERATOR ID (override)" Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
                    <TextBox Text="{Binding OperatorOverride, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding IsRunning, Converter={StaticResource InvertBool}}" />
                </StackPanel>

                <!-- Start / Stop buttons -->
                <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Content="▶  Start Session"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding StartCommand}"
                            Margin="0,0,8,0"
                            Padding="16,8" />
                    <Button Content="■  Stop"
                            Style="{StaticResource DangerButton}"
                            Command="{Binding StopCommand}"
                            Padding="16,8" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Scan mode bar ───────────────────────────────────────── -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,10" Padding="14,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="SCAN MODE:"
                           Style="{StaticResource FieldLabel}"
                           VerticalAlignment="Center"
                           Margin="0,0,14,0" />

                <!-- Manual -->
                <RadioButton Content="Manual Trigger"
                             IsChecked="{Binding IsManualMode, Mode=OneWay}"
                             Command="{Binding SetManualCommand}"
                             VerticalAlignment="Center"
                             Margin="0,0,20,0" />

                <!-- Auto-Poll -->
                <RadioButton Content="Auto-Poll"
                             IsChecked="{Binding IsAutoPollMode, Mode=OneWay}"
                             Command="{Binding SetAutoPollCommand}"
                             VerticalAlignment="Center"
                             Margin="0,0,8,0" />

                <!-- Auto-Poll interval (only shown when that mode is selected) -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            Margin="0,0,20,0"
                            Visibility="{Binding IsAutoPollMode,
                                Converter={StaticResource BoolToVisibility}}">
                    <TextBox Text="{Binding AutoPollIntervalMs, UpdateSourceTrigger=PropertyChanged}"
                             Width="56" Margin="4,0,4,0" />
                    <TextBlock Text="ms" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" />
                </StackPanel>

                <!-- Push (DMST) -->
                <RadioButton Content="Push (DMST)"
                             IsChecked="{Binding IsPushMode, Mode=OneWay}"
                             Command="{Binding SetPushCommand}"
                             IsEnabled="{Binding IsPushAvailable}"
                             VerticalAlignment="Center"
                             Margin="0,0,10,0" />

                <!-- Push port hint -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="{Binding IsPushAvailable,
                                Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="Port: "
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding SelectedDevice.DmstListenPort, Mode=OneWay}"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>

                <!-- Push unavailable hint — shown when DmstListenPort == 0 -->
                <TextBlock Text="(set DmstListenPort &gt; 0 in device profile to enable)"
                           FontSize="11" FontStyle="Italic"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPushAvailable}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ── Live session area ────────────────────────────────────── -->
        <Border Grid.Row="3" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Session header row -->
                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Running indicator -->
                        <Ellipse Width="10" Height="10" Margin="0,0,8,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#BDC3C7" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource SuccessBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Records written: " />
                            <TextBlock Text="{Binding RecordCount, Mode=OneWay}" FontWeight="SemiBold" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Trigger button — Manual and Push modes both support software trigger -->
                    <Button Grid.Column="1"
                            Content="⚡  Trigger Scan"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding TriggerCommand}"
                            Padding="20,10"
                            FontSize="14"
                            Visibility="{Binding ShowTriggerButton,
                                Converter={StaticResource BoolToVisibility}}" />

                    <!-- Auto-Poll running indicator (only for Auto-Poll mode) -->
                    <Border Grid.Column="1"
                            Background="{StaticResource AccentBrush}"
                            CornerRadius="4" Padding="16,8"
                            Visibility="{Binding IsAutoPollMode,
                                Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="⟳  Auto-Polling…"
                                   Foreground="White" FontSize="13" FontWeight="SemiBold"
                                   Visibility="{Binding IsRunning,
                                       Converter={StaticResource BoolToVisibility}}" />
                    </Border>
                </Grid>

                <!-- Status / last result -->
                <Border Grid.Row="1"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="4"
                        Padding="16">
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="14"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </Border>
            </Grid>
        </Border>

        <!-- ── Status bar ──────────────────────────────────────────── -->
        <Border Grid.Row="4" Margin="0,8,0,0" Padding="8,4"
                Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding SelectedDevice.Name}"
                           Style="{StaticResource StatusText}"
                           Margin="0,0,12,0" />
                <TextBlock Text="·" Style="{StaticResource StatusText}" Margin="0,0,12,0" />
                <TextBlock Text="{Binding SelectedTemplate.Name}"
                           Style="{StaticResource StatusText}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
