<UserControl x:Class="VtccpApp.Views.DevicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource SurfaceBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ── Header ──────────────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="Device Profiles"
                       Style="{StaticResource SectionHeader}"
                       Margin="0" VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                <Button Content="+ Add"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding AddCommand}"
                        Margin="0,0,8,0" />
                <Button Content="Edit"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding EditCommand}"
                        Margin="0,0,8,0" />
                <Button Content="Delete"
                        Style="{StaticResource DangerButton}"
                        Command="{Binding DeleteCommand}"
                        Margin="0,0,8,0" />
                <Button Content="Set Default"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding DefaultCommand}" />
            </StackPanel>
        </StackPanel>

        <!-- ── Main content: list + edit form ─────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="320"
                    x:Name="EditPanelCol" />
            </Grid.ColumnDefinitions>

            <!-- Device list -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,8,0">
                <ListView ItemsSource="{Binding Devices}"
                          SelectedItem="{Binding Selected, Mode=TwoWay}"
                          BorderThickness="0"
                          Background="Transparent">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Name"    Width="160"
                                            DisplayMemberBinding="{Binding Name}" />
                            <GridViewColumn Header="Host"    Width="140"
                                            DisplayMemberBinding="{Binding Host}" />
                            <GridViewColumn Header="Port"    Width="60"
                                            DisplayMemberBinding="{Binding Port}" />
                            <GridViewColumn Header="Default" Width="60">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsDefault, Mode=OneWay}"
                                                  IsEnabled="False"
                                                  HorizontalAlignment="Center" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Notes"   Width="200"
                                            DisplayMemberBinding="{Binding Notes}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="6"
                          HorizontalAlignment="Stretch"
                          Background="Transparent"
                          Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}" />

            <!-- Edit panel -->
            <Border Grid.Column="2" Style="{StaticResource Card}"
                    Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel DataContext="{Binding Editing}" Margin="0">

                        <TextBlock Text="Edit Device Profile"
                                   Style="{StaticResource SectionHeader}" />

                        <TextBlock Text="DISPLAY NAME" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="HOST / IP ADDRESS" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="PORT" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="CONNECT TIMEOUT (ms)" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding ConnectMs, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="RESPONSE TIMEOUT (ms)" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding ResponseMs, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="IDLE GAP (ms)" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding IdleGapMs, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="DMST LISTEN PORT (0 = poll mode)" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding DmstPort, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="NOTES" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                 Height="60" TextWrapping="Wrap"
                                 AcceptsReturn="True" VerticalScrollBarVisibility="Auto" />

                        <CheckBox Content="Set as default device"
                                  IsChecked="{Binding IsDefault}"
                                  Margin="0,12,0,0" />

                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                            <Button Content="Save"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding DataContext.SaveCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Margin="0,0,8,0" />
                            <Button Content="Cancel"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding DataContext.CancelCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ── Status bar ──────────────────────────────────────────── -->
        <Border Grid.Row="2" Margin="0,8,0,0" Padding="8,4"
                Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusMessage}"
                       Style="{StaticResource StatusText}" />
        </Border>
    </Grid>
</UserControl>
