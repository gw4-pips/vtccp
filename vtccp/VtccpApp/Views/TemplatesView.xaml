<UserControl x:Class="VtccpApp.Views.TemplatesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource SurfaceBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ── Header ──────────────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="Job Templates"
                       Style="{StaticResource SectionHeader}"
                       Margin="0" VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                <Button Content="+ Add"       Style="{StaticResource PrimaryButton}"
                        Command="{Binding AddCommand}"     Margin="0,0,8,0" />
                <Button Content="Edit"        Style="{StaticResource SecondaryButton}"
                        Command="{Binding EditCommand}"    Margin="0,0,8,0" />
                <Button Content="Delete"      Style="{StaticResource DangerButton}"
                        Command="{Binding DeleteCommand}"  Margin="0,0,8,0" />
                <Button Content="Set Default" Style="{StaticResource SecondaryButton}"
                        Command="{Binding DefaultCommand}" />
            </StackPanel>
        </StackPanel>

        <!-- ── List + Edit ─────────────────────────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition>
                    <ColumnDefinition.Style>
                        <Style TargetType="ColumnDefinition">
                            <Setter Property="Width" Value="360" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="False">
                                    <Setter Property="Width" Value="0" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ColumnDefinition.Style>
                </ColumnDefinition>
            </Grid.ColumnDefinitions>

            <!-- Template list -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,8,0">
                <ListView ItemsSource="{Binding Templates}"
                          SelectedItem="{Binding Selected, Mode=TwoWay}"
                          BorderThickness="0" Background="Transparent">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Name"        Width="180"
                                            DisplayMemberBinding="{Binding Name}" />
                            <GridViewColumn Header="Job Name"    Width="130"
                                            DisplayMemberBinding="{Binding JobName}" />
                            <GridViewColumn Header="Operator"    Width="100"
                                            DisplayMemberBinding="{Binding OperatorId}" />
                            <GridViewColumn Header="Format"      Width="70"
                                            DisplayMemberBinding="{Binding OutputFormat}" />
                            <GridViewColumn Header="Batch Mode"  Width="100"
                                            DisplayMemberBinding="{Binding BatchMode}" />
                            <GridViewColumn Header="Default"     Width="60">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsDefault, Mode=OneWay}"
                                                  IsEnabled="False" HorizontalAlignment="Center" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="6"
                          HorizontalAlignment="Stretch" Background="Transparent"
                          Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}" />

            <!-- Edit panel -->
            <Border Grid.Column="2" Style="{StaticResource Card}"
                    Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
                <!-- Inner grid: fields scroll freely; Save/Cancel row is always visible -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel DataContext="{Binding Editing}">

                            <TextBlock Text="Edit Job Template"
                                       Style="{StaticResource SectionHeader}" />

                            <TextBlock Text="TEMPLATE NAME" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Text="JOB NAME (written to Excel header)"
                                       Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding JobName, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Text="DEFAULT OPERATOR ID" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding OperatorId, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Text="BATCH MODE" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding BatchModeOptions}"
                                      SelectedItem="{Binding BatchMode}" />

                            <TextBlock Text="OUTPUT FORMAT" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding OutputFormatOptions}"
                                      SelectedItem="{Binding OutputFormat}" />

                            <TextBlock Text="ROLL INCREMENT MODE" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding RollModeOptions}"
                                      SelectedItem="{Binding RollMode}" />

                            <TextBlock Text="ROLL START VALUE" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding RollStartValue, UpdateSourceTrigger=PropertyChanged}" />

                            <!-- Output directory -->
                            <TextBlock Text="OUTPUT DIRECTORY (blank = app default)"
                                       Style="{StaticResource FieldLabel}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding OutputDirectory, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,6,0" />
                                <Button Grid.Column="1" Content="…"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="10,4"
                                        Command="{Binding DataContext.BrowseOutputCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}" />
                            </Grid>

                            <!-- Logo path -->
                            <TextBlock Text="LOGO IMAGE PATH (optional)"
                                       Style="{StaticResource FieldLabel}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding LogoPath, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,6,0" />
                                <Button Grid.Column="1" Content="…"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="10,4"
                                        Command="{Binding DataContext.BrowseLogoCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}" />
                            </Grid>

                            <!-- Logo preview -->
                            <Border Margin="0,8" Height="60" BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="4"
                                    Visibility="{Binding LogoPath,
                                        Converter={StaticResource BoolToVisibility}}">
                                <Image Source="{Binding LogoPath}" Stretch="Uniform" />
                            </Border>

                            <CheckBox Content="Set as default template"
                                      IsChecked="{Binding IsDefault}"
                                      Margin="0,12,0,0" />

                            <TextBlock Text="NOTES" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                     Height="50" TextWrapping="Wrap"
                                     AcceptsReturn="True" VerticalScrollBarVisibility="Auto" />

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Save / Cancel — always visible at the bottom of the panel -->
                    <Border Grid.Row="1"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="0,10,0,0"
                            Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Save"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding DataContext.SaveCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Margin="0,0,8,0" />
                            <Button Content="Cancel"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding DataContext.CancelCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ── Status bar ──────────────────────────────────────────── -->
        <Border Grid.Row="2" Margin="0,8,0,0" Padding="8,4"
                Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource StatusText}" />
        </Border>
    </Grid>
</UserControl>
